using { /Verse.org/Tests/VerseTestScriptCmd }

assert:
    T := native_property_rollback_test{}
    set T.MyLogic = true
    if:
        T.MyLogic = true or Err("property test failed")
        set T.MyLogic = false
        T.MyLogic = false or Err("property change failed")
        false? # rollback

    T.MyLogic = true or Err("property rollback failed")


assert:
    T := native_property_rollback_test{}
    set T.MyChar = 'X'
    if:
        T.MyChar = 'X' or Err("property test failed")
        set T.MyChar = 'Y'
        T.MyChar = 'Y' or Err("property change failed")
        false? # rollback

    T.MyChar = 'X' or Err("property rollback failed")


assert:
    T := native_property_rollback_test{}
    set T.MyChar32 = '😄'
    if:
        T.MyChar32 = '😄' or Err("property test failed")
        set T.MyChar32 = '❌'
        T.MyChar32 = '❌' or Err("property change failed")
        false? # rollback

    T.MyChar32 = '😄' or Err("property rollback failed")


