# --- Public ---
assert_valid
{
    A := interface:
        
        myMember<public>:int

    B := class(A):
        myFunction(param:A):int=
            param.myMember
}

assert_valid
{
    A := interface:
        
        myMember<public>:int

    B := class:
        myFunction(param:A):int=
            param.myMember
}

assert_valid
{
    A := interface:
        
        myFunction<public>():int=
            5

    B := class(A):
        myOtherFunction(param:A):int=
            param.myFunction()
}

assert_valid
{
    A := interface:
        
        myFunction<public>():int=
            5

    B := class:
        myOtherFunction(param:A):int=
            param.myFunction()
}

# --- Private ---
assert_semantic_error(3593)
{
    A := interface:

        myMember<private>:int = 7

    B := class(A):
        myFunction():int=
            myMember
}

assert_semantic_error(3593)
{
    A := interface:

        myMember<private>:int = 8

    B := class:
        myFunction(param:A):int=
            param.myMember
}

assert_semantic_error(3593)
{
    A := interface:

        myFunction<private>():int=
            5

    B := class(A):
        myOtherFunction():int=
            myFunction()
}

assert_semantic_error(3593)
{
    A := interface:
        
        myFunction<private>():int=
            5
    
    B := class:
        myOtherFunction(param:A):int=
            param.myFunction()
}

# --- Protected ---
assert_valid
{
    A := interface:

        myMember<protected>:int = 7

    B := class(A):
        myFunction():int=
            myMember
}

assert_semantic_error(3593)
{
    A := interface:

        myMember<protected>:int = 8

    B := class:
        myFunction(param:A):int=
            param.myMember
}

assert_valid
{
    A := interface:

        myFunction<protected>():int=
            5

    B := class(A):
        myOtherFunction():int=
            myFunction()
}

assert_semantic_error(3593)
{
    A := interface:
        
        myFunction<protected>():int=
            5
    
    B := class:
        myOtherFunction(param:A):int=
            param.myFunction()
}

# --- Internal ---
assert_valid
{
    vmodule(X):
        snippet:
            A := interface:
                # default access := internal
                myMember:int

            B := class:
                myFunction(a:A):int=
                    a.myMember
}

assert_valid
{
    vmodule(X):
        snippet:
            A := interface:
                
                myMember<internal>:int

            B := class:
                myFunction(a:A):int=
                    a.myMember
}

assert_semantic_error(3593)
{
    vmodule(X):
        snippet:
            
            A<public> := interface<internal>:
                
                myMember<internal>:int

    vmodule(Y):
        snippet:
            using{X}
            B := class:
                myFunction(a:A):int=
                    a.myMember
}


assert_valid
{
    vmodule(X):
        snippet:
            A := interface:
                # default access := internal
                myFunction():int=
                    5

            B := class(A):
                myOtherFunction():int=
                    myFunction()
}

assert_valid
{
    vmodule(X):
        snippet:
            A := interface:
                
                myFunction<internal>():int=
                    5

            B := class(A):
                myOtherFunction():int=
                    myFunction()
}

assert_semantic_error(3593)
{
    vmodule(X):
        snippet:
            
            A<public> := interface:
                # default access := internal
                myFunction():int=
                    5

    vmodule(Y):
        snippet:
            using{X}
            B := class(A):
                myOtherFunction():int=
                    myFunction()
}

assert_semantic_error(3593)
{
    vmodule(X):
        snippet:
            
            A<public> := interface:
                
                myFunction<internal>():int=
                    5

    vmodule(Y):
        snippet:
            using{X}
            B := class(A):
                myOtherFunction():int=
                    myFunction()
}


# --- Ensure single access level ---

assert_semantic_error(3543):
    A := interface:
        myFunction<public><internal>():int=
            return (42)

assert_semantic_error(3543):
    A := interface:
        myData<public><private><protected><internal>:int = 42

# Allow ambiguity as long as only one choice is accessible
<#   
# Doesn't work for types
assert_valid:
    vmodule(X):
        snippet:
            A<public> := interface{}
    vmodule(Y):
        snippet:
            A<internal> := interface{}
    vmodule(Z):
        snippet:        
            using{ X }
            using{ Y }
            B := class(A){} # Should not be ambiguous and refer to X.A since Y.A is inaccessible
#>


# The accessibility of members with no default value must be no less than the interface's constructor.
assert_valid                {access_test_i1<public>   := interface          {AccessTestX<public>:int}}
assert_semantic_error(3593) {access_test_i2<public>   := interface          {AccessTestX<internal>:int}}
assert_semantic_error(3593) {access_test_i3<public>   := interface          {AccessTestX<protected>:int}}
assert_semantic_error(3593) {access_test_i4<public>   := interface          {AccessTestX<private>:int}}
assert_semantic_error(3593) {access_test_i5<public>   := interface          {AccessTestX<epic_internal>:int}}

assert_valid                {access_test_i6<internal> := interface          {AccessTestX<public>:int}}
assert_valid                {access_test_i7<internal> := interface          {AccessTestX<internal>:int}}
assert_semantic_error(3593) {access_test_i8<internal> := interface          {AccessTestX<protected>:int}}
assert_semantic_error(3593) {access_test_i9<internal> := interface          {AccessTestX<private>:int}}

assert_valid                {access_test_i10<public> := interface<internal> {AccessTestX<public>:int}}
assert_valid                {access_test_i11<public> := interface<internal> {AccessTestX<internal>:int}}
assert_semantic_error(3593) {access_test_i12<public> := interface<internal> {AccessTestX<protected>:int}}
assert_semantic_error(3593) {access_test_i13<public> := interface<internal> {AccessTestX<private>:int}}

# An epic_internal interface constructor follows the same rule as a class one (cf. access_test_c21-c25
# in Classes/AccessSpecifiers.versetest): a member with no default must be at least as accessible as
# the constructor.
assert_valid                {access_test_i14<epic_internal> := interface {AccessTestX<public>:int}}
assert_semantic_error(3593) {access_test_i15<epic_internal> := interface {AccessTestX<internal>:int}}
assert_semantic_error(3593) {access_test_i16<epic_internal> := interface {AccessTestX<protected>:int}}
assert_semantic_error(3593) {access_test_i17<epic_internal> := interface {AccessTestX<private>:int}}
assert_valid                {access_test_i18<epic_internal> := interface {AccessTestX<epic_internal>:int}}

# A default value waives that requirement, since the constructor no longer needs the caller to
# supply the field.
assert_valid                {access_test_i19<epic_internal> := interface {AccessTestX<protected>:int = 0}}
assert_valid                {access_test_i20<epic_internal> := interface {AccessTestX<private>:int = 0}}