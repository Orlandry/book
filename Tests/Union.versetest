u2_ := union{U3:u3_}
u3_ := union{V:void}

UF0(U:u1_):logic=
    case(U):
        u1_.U2(U2 : u2_) => true
        _=> false

assert:
    UF0(u1_.U2(u2_.U3(u3_.V()))) = true

assert:
    UF0(u1_.V()) <> true

assert:
    MU := u1_.U2(u2_.U3(u3_.V()))
    logic{Equal[u1_.U2(u2_.U3(u3_.V())), MU]} = true

assert:
    MU := u1.N(1)
