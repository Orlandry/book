    Foo(U:u):void=
        logic{
        case(U):
            u.V() =>
            u.S("String") =>    
        }

# Not fully exhausted case is decides
assert_valid:
    e := enum{A}
    Foo(E:e)<decides>:void=
        case(E):
            e.A =>
    
