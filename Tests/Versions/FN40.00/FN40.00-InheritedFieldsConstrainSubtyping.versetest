<# Disabled pending fix for FORT-1017607
using {/Verse.org/Tests/VerseTestScriptCmd}

# Incorrectly treats i1 as bivariant instead of covariant pre-40.00
assert_valid:
    vpackage(P0, /Verse.org/Verse, ?Scope:=PublicAPI):
        snippet:
            covariant_interface(t:type) := interface{Field:t}
            interface_inheriting_covariant_interface(t:type) := interface(covariant_interface(t)) {}
    vpackage(P1, /Verse.org/Verse, ?Dependencies:=(P0), ?Scope:=PublicAPI, ?UploadedAtFNVersion:=3999):
        snippet:
            F(X:interface_inheriting_covariant_interface(int)) : interface_inheriting_covariant_interface(float) = X

assert_semantic_error(3510):
    vpackage(P0, /Verse.org/Verse, ?Scope:=PublicAPI):
        snippet:
            covariant_interface(t:type) := interface{Field:t}
            interface_inheriting_covariant_interface(t:type) := interface(covariant_interface(t)) {}
    vpackage(P1, /Verse.org/Verse, ?Dependencies:=(P0), ?Scope:=PublicAPI, ?UploadedAtFNVersion:=4000):
        snippet:
            F(X:interface_inheriting_covariant_interface(int)) : interface_inheriting_covariant_interface(float) = X

