# Override of a data member from a class in an @available-gated module should use
# parenthesized type qualifier in the digest, not dot-access into the module.
assert_digest_generated
{
    vpackage(P0, /A, ?Scope := InternalUser):
        snippet:
            using { /Verse.org/Native }
            Unrelated<public> := module:
                Field<public>:int = 99

            @available{MinUploadedAtFNVersion:=1337}
            Module<public> := module:
                Base<public> := class:
                    Field<public>:int = 0

            using { /A/Module }
            Child<public> := class(Module.Base):
                Field<override>:int = 1

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        using {/A}
        using {/Verse.org/Native}
        # Module import path: /A/Unrelated
        Unrelated<public> := module:
            Field<public>:int = external{}

        @available{MinUploadedAtFNVersion:=1337}
        # Module import path: /A/Module
        Module<public> := module:
            Base<public> := class:
                (/A/Module/Base:)Field<public>:int = external{}

        Child<public> := class((/A:)Module.Base):
            ((/A:)Module.Base:)Field<override>:int = external{}
}

