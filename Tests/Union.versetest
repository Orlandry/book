    logic{Equal[MU, s{N:=1}]} = false

us := union{ S0 : string, S1 : string}
assert:
    MU : us = us.S0("buzz")
    not Equal[MU, "buzz"]
    logic{Equal[MU, us.S1("buzz")]} = false

e := enum{A, B}
ue := union{A : void, B : void}
