using { /Verse.org/Native }
using {/Verse.org/Tests/VerseTestScriptCmd}
using { /Verse.org/Concurrency }

# Make sure union macro is not supported in the BPVM
bp_vm_only
{
# Macro 'union' does not exist in BPVM
assert_semantic_error(3506){U := union{}}
}



verse_vm_only
{
# Macro 'union' is epic_internal — gate at SemanticAnalyzer.cpp:13376 rejects non-Epic packages
assert_semantic_error(3506) { vpackage(P,/NotVerse.org,?Scope:=PublicUser) { snippet { U := union{N:int} } } }

assert_semantic_error(3619) { u:=union{}}
assert_valid { u:=union{U:u}}
assert_semantic_error(3547) { u:=union{V : void}; U:=u.V()} # Unions can't be implicitly defined
assert_semantic_error(3547) { e:=enum{A}; E:=e.A} # Enums also can't implicitly be defined
assert_valid { U:=union{V : void}}
assert_valid { U:=union{T : tuple(int, int)}}
assert_valid { U:=union{N0 : int, N1 : int}}
assert_semantic_error(3596) { U:=union<open>{N0 : int, N1 : string, V : void}}
assert_semantic_error(3596) { U:=union<closed>{N : int, S : string, V : void}}
assert_valid { U:=union{N:int}; UM: [U]int = map{}}
assert_semantic_error(3628, 3628) {u:=union{ A : void, A : int, A : string}}
assert_semantic_error(3628, 3628) {u:=union{ V : void, V : void, V : void}}

assert_valid{u := union{V:void}; MyArray:[]u = array{}}
assert_valid{u := union{V:void}; MyArray:[]u = array{u.V()}}
assert_semantic_error(3509){u0 := union{V:void}; u1 := union{V:void}; MyArray:[]u0 = array{u1.V()}}

# Test that you can't define two union types with the same name.
assert_semantic_error(3532){ u:=union{a:void}; u:=union{b:void} }

# Test that you can't use the union macro except as the direct RHS of a definition.
assert_semantic_error(3560){ union{Empty : void} }
assert_semantic_error(3606){ C:=-union{Empty : void} }
assert_semantic_error(3606,3547){ C:=union{Empty : void}+1 }
assert_semantic_error(3502){ f():void= union{Empty : void} }
assert_semantic_error(3502){ f():void={union{Empty : void}}}
assert_semantic_error(3547){ u := union{Empty : void}; U := u.Empty() }

# Test that you can't define a local union type.
assert_semantic_error(3502){ f():void={ u:=union{V : void} } }

# Malformed variant definition
assert_semantic_error(3540){ u := union{ : int}}
assert_semantic_error(3546){ u := union{ Empty }}
assert_semantic_error(3546){ u := union{ Empty() : void }}
assert_semantic_error(3547){ u := union{ Empty : void() }}

assert_valid:
    NoDupeUnionValues := union:
        V : void
        N : int

    NoDupeUnionValues2 := union:
        V : void
        N : int

assert_semantic_error(3628):
    DuplicateVariants := union:
        S : string
        S : string

assert_semantic_error(3532):
    DuplicateVariantIdentifiers := union:
        S : string

    DuplicateVariantIdentifiers := union:
        S : string

assert_valid:
    S:string=""
    SomeUnion := union:
        (SomeUnion:)S : string
        V : void
        N : int

assert_valid:
    u := union{V:void}
    c := class:
        U : u = u.V()
        UO : ?u = false
        UM : [u]int = map{ u.V() => 0}
        UMV : [int]u = map{ 0 => u.V()}    
        UA : []u = array{}

# Cannot compare a comparable vs. noncomparable 
assert_semantic_error(3509, 3512):
    some_class := class{}
    u := union {N : int, C : some_class }
    l : logic = logic{u.C(some_class{}) = u.N(42)} 

inttree := union:
    Empty : void
    Leaf : int
    Node : node    

node := struct<computes>:
    Left : inttree
    Value : int
    Right : inttree

Sum(T: inttree) : int = {
  case (T) {
    inttree.Node(N : node) =>
        N.Value + Sum(N.Left) + Sum(N.Right)
    inttree.Leaf(Number : int) =>
        Number
    inttree.Empty() => 0
  }
}

IntTreeLeaf : inttree = inttree.Leaf(1)
DeadEndNode : node = node{Left:=IntTreeLeaf, Value:=2, Right:=IntTreeLeaf}
IntTreeDeadEnd : inttree = inttree.Node(DeadEndNode)
IntTreeNode : node = node{Left:=IntTreeLeaf, Value:=2, Right:=IntTreeDeadEnd}
IntTree : inttree = inttree.Node(IntTreeNode)

assert:
    Sum(IntTree) = 7

# You can use a union as its own a payload type
assert_valid:
    u := union{ U : u, V : void}

ru := union{ U : ru, V : void}

assert_valid:
    ru := union{ U : ru, V : void}
    U : ru = ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.V()))))))))))))))))))))))))

assert_semantic_error(3502):
    ru := union{ U : ru, V : void}
    U : ru = ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.V))))))))))))))))))))))))

# Void variant payload case is resolved properly
assert:
    U : ru = ru.V()
    Foo(_U:ru):int=
        case(_U):
            ru.U(LU : ru) => Foo(_U) + 1
            ru.V() => 0
    Foo(U) = 0

# finite recursion
assert:
    U : ru = ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.U(ru.V()))))))))))))))))))))))))
    Foo(_U:ru):int=
        case(_U):
            ru.U(LU : ru) => Foo(LU) + 1
            ru.V() => 0
    Foo(U) = 24
   
u := union {N0:int, N1:int, V:void}

assert:
    FlipFlop(U:u):u=
        case(U):
            u.N0(X:int)=> u.N1(X)
            u.N1(X:int)=> u.N0(X)
            _=> u.V()

    FlipFlop(u.N0(6)) = u.N1(6)

# Wildcard with max payload causes error
assert_semantic_error(2302):
    u := union {A:int, B:int, C:void}

    FlipFlop(U:u):u=
        case(U):
            u.A(X:int)=> u.B(X)
            u.B(X:int)=> u.A(X)
            u.C() => u.C()
            _=> u.C() #Invalid wildcard - we hit max already

# Not handling all values
assert_semantic_error(3512):
    u := union {N0:int, N1:int, V:void}
    FlipFlop(U:u):u=
        case(U):
            u.N0(X:int)=> u.N1(X)
            u.N1(X:int)=> u.N0(X)

# Can't case over a union that is not owned by the LHS
assert_semantic_error(3618):
    u1 := union {AN:int}
    u2 := union {BN:int}
    Foo(U:u1):void=
        case(U):
            u2.BN(X:int)=>

# You can't have a function as a union in a case
assert_semantic_error(3617, 3618):
    u1 := union {N:int}
    f0():void={}
    U1 : u1 = u1.N(1)
    f1():void=
        case(U1):
            f0() =>
            _=>    

u1 := union:
    N:int
    S : string
    V : void
    
u2 := union:
    N:int
    S : string
    V : void

assert{u1.N(1) = u1.N(1)}
assert{u1.N(1) <> u1.N(2)}

# Maps
U1Map : [u1]int = map {u1.N(67) => 0, u1.V() => 1}

assert:
    U1Int := U1Map[u1.N(67)] or Err()
    U1Int = 0

assert:
    U1Int := U1Map[u1.V()] or Err()
    U1Int = 1

assert:
    var SomeUnionMap : [u1]int = map{}
    set SomeUnionMap[u1.S("Fizz")] = 6
    SomeUnionMap[u1.S("Fizz")] = 6
    logic{SomeUnionMap[u1.S("Buzz")]} = false

assert:
    var SomeUnionMap : [int]u1 = map{}
    set SomeUnionMap[0] = u1.N(6)
    SomeUnionMap[0] = u1.N(6)
    SomeUnionMap[0] <> u1.N(7)

assert_semantic_error(3547, 3502):
    u1 := union:
        N:int
        S : string
        V : void
    SomeUnion := u1.S
    
assert:
    logic{U1Map[u1.S("Buzz")]} = false

assert:
    U1 : u1 = u1.N(1)
    U2 : u2 = u2.N(1)
    U1 <> U2

assert:
    U1 : u1 = u1.N(1)
    U2 : u2 = u2.N(1)
    not U1 = U2
    

assert:
    V1 : u1 = u1.N(1)
    V2 : u1 = u1.N(1)
    V1 = V2

GU1() : u1 = u1.V()
IsV(PU1 : u1) : logic =
    case(PU1):
        u1.V() => true
        u1.S(S : string) => false
        _=> false

assert:
    IsV(GU1()) = true

assert:
    IsV(u1.S("Fizz")) = false

assert:
    GU1() = u1.V()

assert:
    var U1 : u1 = u1.S("Fizz")
    U1 = u1.S("Fizz")

assert:
    var U1 : u1 = u1.V()
    U1 = u1.V()
    set U1 = u1.S("Fizz")
    U1 = u1.S("Fizz")

GU1_ : u1 = u1.V()

assert{GU1_ = u1.V()}

# Join
assert_valid:
    u := union{N:int}
    U1 : u = u.N(0)
    U2 : u = u.N(1)
    UA : []u = array{U1, U2}

