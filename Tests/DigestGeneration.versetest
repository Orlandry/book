# Variance and subclasses
<# Disabled pending fix for FORT-1017607
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class:
                Data:?t = false
            class2<public>(t:type) := class(class1(t)) {}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        using {/Verse.org/Native}
        class1<public>(t:type) := class:
            (/A/class1:)class1_Variance<private>():tuple(t) = external{}
        class2<public>(t:type) := class(class1(t)):
            @available{MinUploadedAtFNVersion:=4000}
            (/A/class2:)class2_Variance_Inherited<private>():tuple(t) = external{}
}
#>

assert_valid:
    class1<public>(t:type) := class:
        class2_Variance<public>:int = 0
    class2<public>(t:type) := class(class1(t)):
        F():int = class2_Variance

assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class:
                class2_Variance<public>:int = 0
            class2<public>(t:type) := class(class1(t)):
                Data:?t = false

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type) := class:
            class2_Variance<public>:int = external{}
        class2<public>(t:type) := class(class1(t)):
            (/A/class2:)class2_Variance0<private>():tuple(t) = external{}
}

