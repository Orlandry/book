# Check that backwards compatibility subtyping constraints that span the UploadedAtFNVersion threshold
# use the "new" definition's UploadedAtFNVersion to check the subtyping.

# Compatible because new Data is a subtype of old Data.
assert_valid:
    vpackage(P0, /Common):
        snippet:
            super_class<public> := class{}
            sub_class<public> := class(super_class){}
            covariant_class<public>(t:type) := class{X<public>:t}
            class_inheriting_covariant_class<public>(t:type) := class(covariant_class(t)) {}
    vpackage(P0, /A, ?Dependencies:=(P0), ?Scope:=PublicUser, ?Role:=GeneralCompatConstraint, ?UploadedAtFNVersion:=3999):
        snippet:
            using{/Common}
            Data<public>:?class_inheriting_covariant_class(super_class) = false
    vpackage(P1, /A, ?Dependencies:=(P0), ?Scope:=PublicUser, ?Role:=Source, ?UploadedAtFNVersion:=4000):
        snippet:
            using{/Common}
            Data<public>:?class_inheriting_covariant_class(sub_class) = false

# Not compatible because new Data is not a subtype of old Data.
assert_semantic_error(3645):
    vpackage(P0, /Common):
        snippet:
            super_class<public> := class{}
            sub_class<public> := class(super_class){}
            covariant_class<public>(t:type) := class{X<public>:t}
            class_inheriting_covariant_class<public>(t:type) := class(covariant_class(t)) {}
    vpackage(P0, /A, ?Dependencies:=(P0), ?Scope:=PublicUser, ?Role:=GeneralCompatConstraint, ?UploadedAtFNVersion:=3999):
        snippet:
            using{/Common}
            Data<public>:?class_inheriting_covariant_class(sub_class) = false
    vpackage(P1, /A, ?Dependencies:=(P0), ?Scope:=PublicUser, ?Role:=Source, ?UploadedAtFNVersion:=4000):
        snippet:
            using{/Common}
            Data<public>:?class_inheriting_covariant_class(super_class) = false

# Compatible because new Data is a subtype of old Data according to new Data's old UploadedAtFNVersion.
assert_valid:
    vpackage(P0, /Common):
        snippet:
            super_class<public> := class{}
            sub_class<public> := class(super_class){}
            covariant_class<public>(t:type) := class{X<public>:t}
            class_inheriting_covariant_class<public>(t:type) := class(covariant_class(t)) {}
    vpackage(P0, /A, ?Dependencies:=(P0), ?Scope:=PublicUser, ?Role:=GeneralCompatConstraint, ?UploadedAtFNVersion:=3999):
        snippet:
            using{/Common}
            Data<public>:?class_inheriting_covariant_class(sub_class) = false
    vpackage(P1, /A, ?Dependencies:=(P0), ?Scope:=PublicUser, ?Role:=Source, ?UploadedAtFNVersion:=3999):
        snippet:
            using{/Common}
            Data<public>:?class_inheriting_covariant_class(super_class) = false

# The variance constraints created by the digest generator for inherited definitions should include
# an @available constraint to ensure they doesn't constrain pre-40.00 uploads that use the digest.
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            internal_interface(t:type) := interface:
                Data<private>:?t = false
            public_interface<public>(t:type) := interface(internal_interface(t)):
                Data2<private>:?(t->void)=false

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        using {/Verse.org/Native}
        public_interface<public>(t:type) := interface:
            @available {MinUploadedAtFNVersion := 4000}
            (/A/public_interface:)public_interface_Variance_Inherited<private>():tuple(t) = external {}

            (/A/public_interface:)public_interface_Variance<private>(:t):tuple() = external {}
}

# Test that @available fields only constrain variance for subtyping checks from packages that meet the @available criteria.
assert_valid:
    vpackage(P0, /Verse.org/Verse, ?Scope:=InternalAPI):
        snippet:
            using{/Verse.org/Native}
            covariant_class<public>(t:type) := class:
                @available{MinUploadedAtFNVersion:=4000}
                Variance<public>:?t = false

    vpackage(P1, /B, ?Dependencies:=(P0), ?UploadedAtFNVersion:=3999):
        snippet:
            F(X:covariant_class(int)):covariant_class(float)=X

assert_semantic_error(3510):
    vpackage(P0, /Verse.org/Verse, ?Scope:=InternalAPI):
        snippet:
            using{/Verse.org/Native}
            covariant_class<public>(t:type) := class:
                @available{MinUploadedAtFNVersion:=4000}
                Variance<public>:?t = false

    vpackage(P1, /B, ?Dependencies:=(P0), ?UploadedAtFNVersion:=4000):
        snippet:
            F(X:covariant_class(int)):covariant_class(float)=X
#>
