class4 := class:
    Property:int
    Method(X:t where t:type):tuple(int, t) = (Property, X)

ApplyThenAdd(F(:int):tuple(int, int), X:int):int =
    Y := F(X)
    Y(0) + Y(1)

assert:
    X := class4{Property := 1}
    ApplyThenAdd(X.Method, 2) = 3

# This correctly fails only with incremental compilation
# Main()<decides>:void =
#     X := TestImplicitTypeParams.class1{Property := 1}
#     ApplyThenAdd(X.Method, 2) = 3

# Ensure intrinsic parametric functions work
TestSlice<public>(Source:[]t, StartIndex:int, EndIndex:int where t:type)<transacts><decides>:[]t =
    for (Index := StartIndex..(EndIndex - 1)):
        Source[Index]

TestInsert<public>(Source:[]t, InsertionIndex:int, Element:t where t:type)<transacts><decides>:[]t=
    TestSlice[Source, 0, InsertionIndex] + array{Element} + TestSlice[Source, InsertionIndex, Source.Length]

assert:
    X := array{1, 2, 3}
    Y:[]int = TestInsert[X, 1, 4]
    Y = array{1, 4, 2, 3}

assert:
    X := (1, 2)
    Y := (3, 4)
    (X + Y) = array{1, 2, 3, 4}

assert:
    X := array{1, 2, 3}
    Y:[]int = TestInsert[X, 1, 4]
    Y = array{1, 4, 2, 3}

assert:
    X := (1, 2)
    Y := (3, 4)
    (X + Y) = array{1, 2, 3, 4}

assert_semantic_error(3552):
    Var := module:
        c<public>(t:type) := class:
            var Data<public>:t
        F<public>(X:t where t:type)<transacts>:c(t) = c(t):
            Data := X

assert_semantic_error(3552):
        Var := module:
        c<public>(t:type) := class:
            var Data<public>:t
        F<public>(X:c(t) where t:type)<transacts>:void = {}

Var := module:
    c<public>(t:type) := class:
        var Data<public>:t
    s1<public> := struct<computes>:
        Data:int
    s2<public>(t:type) := struct<computes>:
        Data:t
    F<public>(t:type, X:t)<transacts>:c(t) = c(t):
        Data := X

assert:
    X := Var.F(comparable, 1)
    set X.Data = "hello"
    X.Data = "hello"

assert:
    X := Var.F(int, 1)
    set X.Data += 2
    X.Data = 3

assert:
    X := Var.F(type{Y:int where Y >= 1, Y <= 2}, 1)
    set X.Data = 2
    X.Data = 2

assert:
    X := Var.F([]int, array{1, 2})
    set X.Data[0] = 3
    X.Data[0] = 3
    X.Data[1] = 2

assert:
    X := Var.F(Var.s1, Var.s1{Data := 1})
    set X.Data.Data = 2
    X.Data.Data = 2

assert:
    X := Var.F(Var.s2(int), Var.s2(int){Data := 1})
    set X.Data.Data = 2
    X.Data.Data = 2

assert:
    X := Var.F(Var.s2(int), Var.s2(int){Data := 1})
    set X.Data.Data += 2
    X.Data.Data = 3

assert:
    X := Var.F(Var.s2([]int), Var.s2([]int){Data := array{1, 2}})
    set X.Data.Data[0] = 3
    X.Data.Data[0] = 3
    X.Data.Data[1] = 2

assert_semantic_error(3502):
    InterfaceVar := module:
        i<public>(t:type) := interface:
            var Data<public>:t

assert_valid:
    vpackage(P1,/A,?Role:=Source,?Scope:=PublicUser,?UploadedAtFNVersion:=4000):
        snippet:
            InterfaceVar := module:
                i<public>(t:type) := interface:
                    var Data<public>:t

assert_semantic_error(3509):
    c(t:type) := class:
        var X:t
    F(t:type, X:t)<transacts>:c(t) = c(t):
        X := X
    G(X:type{Y:int where Y <= 1}):void = {}
    H():void =
        X := F(type{Y:int where Y >= 1, Y <= 2}, 1)
        set X.X = 2
        G(X.X)

assert_valid:
    c(t:type) := class:
        Method(X:t):t = X
    F(X:t where t:type):c(t)=
        c(t){}
    G():void=
        F(1).Method(2)

# Ensure `var` type with nested implicit type parameters are allowed.
assert_valid:
    c0(t:type) := class:
        var Data:c1
    c1 := class:
        Method(Arg:t where t:type):t = Arg
    F(Arg:t where t:type):c0(t) = c0(t):
        Data := c1{}    

MutationLoophole := module:
    (MutationLoophole:)class1(t:type) := class:
        var Data:t
        Get():t = Data
        Set(Arg:t):void = set Data = Arg
    F<public>(Arg:t where t:type):tuple(tuple() -> t, t -> void) =
        Obj := (MutationLoophole:)class1(t):
            Data := Arg
        Obj.Get, Obj.Set

assert:
    Ref := MutationLoophole.F(1)
    Ref(0)() = 1
    # Required so a function coercion isn't required.
    Two:comparable = 2
    Ref(1)(Two)
    Ref(0)() = Two

# Include superclass and implemented interfaces when performing polarity use check.
assert_valid:
    interface1(t:type) := interface:
        Method()<suspends>:t

    interface2(t:type) := interface(interface1(t)) {}
    
    F(X:interface2(t) where t:type):interface2(t) = X

assert_valid:
    interface1(t:type) := interface:
        Method(:t)<suspends>:void = {}

    class1(t:type) := class(interface1(t)):
    
    F(X:class1(t) where t:type):class1(t) = X

assert_valid:
    class1(t:type) := interface:
        Method(:t)<suspends>:void = {}

    class2(t:type) := class(class1(t)):
    
    F(X:class2(t) where t:type):class2(t) = X

# Include map key and value type when performing polarity use check.
assert_valid:
    F(X:[t]u where t:subtype(comparable), u:type):[t]u = X

assert_valid:
    Foo(:castable_subtype(t) where t:type):void = {}

assert_semantic_error(3503, 3503):
    Foo(X:int where t:subtype(u), u:type):?t = false

assert_valid:
    Foo(X:t where t:subtype(u), u:type):t = X

# Ensure we don't cycle following a type variable's constraints.
assert_semantic_error(3506):
    F(X:t where t:subtype(u), u:subtype(t)):void =
        X.Foo

RepeatedTupleInstantiation := module:
    (RepeatedTupleInstantiation:)class1<public>(t:type) := class:
        Data<public>:class2(tuple(int, t))
        Method<public>(Arg1:int, Arg2:t)<computes><decides>:void =
            Data.Method[Arg1, Arg2]
    (RepeatedTupleInstantiation:)class2<public>(t:type) := class:
        Data<public>:type{_(:t)<computes><decides>:void}
        Method<public>(Arg:t)<computes><decides>:void =
            Data[Arg]
    class3<public> := class<unique> {}
    A<public>(Arg1:int, Arg2:class3)<computes><decides>:void =
        Arg1 = 1

assert:
    X := RepeatedTupleInstantiation.class3{}
    Y := RepeatedTupleInstantiation.class1(RepeatedTupleInstantiation.class3):
        Data := RepeatedTupleInstantiation.class2(tuple(int, RepeatedTupleInstantiation.class3)):
            Data := RepeatedTupleInstantiation.A
    Z := RepeatedTupleInstantiation.class3{}
    Y.Method[1, Z]
    not Y.Method[2, Z]

RepeatedOptionInstantiation := module:
    (RepeatedOptionInstantiation:)class1<public>(t:type) := class:
        Data<public>:class2(?t)
        Method<public>(Arg:?t)<computes><decides>:void =
            Data.Method[Arg]
    (RepeatedOptionInstantiation:)class2<public>(t:type) := class:
        Data<public>:type{_(:t)<computes><decides>:void}
        Method<public>(Arg:t)<computes><decides>:void =
            Data[Arg]
    class3<public> := class<unique> {}
    B<public>(Arg:?class3)<computes><decides>:void =
        Arg?

assert:
    X := RepeatedOptionInstantiation.class3{}
    Y := RepeatedOptionInstantiation.class1(RepeatedOptionInstantiation.class3):
        Data := RepeatedOptionInstantiation.class2(?RepeatedOptionInstantiation.class3):
            Data := RepeatedOptionInstantiation.B
    Y.Method[option{RepeatedOptionInstantiation.class3{}}]
    not Y.Method[false]

RepeatedArrayInstantiation := module:
    (RepeatedArrayInstantiation:)class1<public>(t:type) := class:
        Data<public>:class2([]t)
        Method<public>(Arg:[]t)<computes><decides>:void =
            Data.Method[Arg]
    (RepeatedArrayInstantiation:)class2<public>(t:type) := class:
        Data<public>:type{_(:t)<computes><decides>:void}
        Method<public>(Arg:t)<computes><decides>:void =
            Data[Arg]
    class3<public> := class<unique> {}
    C<public>(Arg:[]class3)<computes><decides>:void =
        Arg.Length = 1

assert:
    X := RepeatedArrayInstantiation.class3{}
    Y := RepeatedArrayInstantiation.class1(RepeatedArrayInstantiation.class3):
        Data := RepeatedArrayInstantiation.class2([]RepeatedArrayInstantiation.class3):
            Data := RepeatedArrayInstantiation.C
    Y.Method[array{RepeatedArrayInstantiation.class3{}}]
    not Y.Method[]

RepeatedMapInstantiation := module:
    (RepeatedMapInstantiation:)class1<public>(t:subtype(comparable)) := class:
        Data<public>:class2([t]t)
        Method<public>(Arg:[t]t)<computes><decides>:void =
            Data.Method[Arg]
    (RepeatedMapInstantiation:)class2<public>(t:type) := class:
        Data<public>:type{_(:t)<computes><decides>:void}
        Method<public>(Arg:t)<computes><decides>:void =
            Data[Arg]
    class3<public> := class<unique> {}
    D<public>(Arg:[class3]class3)<computes><decides>:void =
        Arg.Length = 1
        for (X->Y:Arg). X = Y

assert:
    X := RepeatedMapInstantiation.class3{}
    Y := RepeatedMapInstantiation.class1(RepeatedMapInstantiation.class3):
        Data := RepeatedMapInstantiation.class2([RepeatedMapInstantiation.class3]RepeatedMapInstantiation.class3):
            Data := RepeatedMapInstantiation.D
    Z := RepeatedMapInstantiation.class3{}
    Y.Method[map{Z => Z}]
    not Y.Method[map{}]
    not Y.Method[map{Z => RepeatedMapInstantiation.class3{}}]

RepeatedVarInstantiation := module:
    (RepeatedVarInstantiation:)class1<public>(t:type) := class:
        Data<public>:class2(tuple(int, t))
        Method<public>(Arg1:int, Arg2:t):void =
            Data.Method(Arg1, Arg2)
    (RepeatedVarInstantiation:)class2<public>(t:type) := class:
        var Data<public>:t
        Method<public>(Arg:t):void =
            set Data = Arg
    class3<public> := class<unique> {}

assert:
    X := RepeatedVarInstantiation.class3{}
    Y := RepeatedVarInstantiation.class1(RepeatedVarInstantiation.class3):
        Data := RepeatedVarInstantiation.class2(tuple(int, RepeatedVarInstantiation.class3)):
            Data := (1, X)
    Y.Data.Data = (1, X)
    Y.Method(2, X)
    Y.Data.Data = (2, X)
    Y.Data.Method(3, X)
    Y.Data.Data = (3, X)
    Y.Method(4, X)
    Y.Data.Data = (4, X)

assert_valid:
    VarInRecursiveData := module:
        class1 := class:
            F(X:t where t:type):tuple(t, class2) = (X, class2{})
        class2 := class:
            var Data:?class1 = false

array_ref(t:type) := class:
    var Contents:[]t = ()

assert:
    IntArrayRef := array_ref(int){}
    set IntArrayRef.Contents = array. 1
    IntArrayRef.Contents = array. 1

int_map_ref(t:type) := class:
    var Contents:[int]t = map{}

assert:
    IntIntMapRef := int_map_ref(int){}
    set IntIntMapRef.Contents = map{1 => 2}
    IntIntMapRef.Contents = map{1 => 2}

assert:
    X := array_ref(int_map_ref(int)){}
    set X.Contents = array. int_map_ref(int){}
    set X.Contents[0].Contents = map{1 => 2}
    X.Contents[0].Contents = map{1 => 2}
