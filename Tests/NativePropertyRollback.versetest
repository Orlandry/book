    set T.MyString = "meow"
    if:
        T.MyString = "meow" or Err("property test failed")
        set T.MyString = "woof"
        T.MyString = "woof" or Err("property change failed")
        false? # rollback

    T.MyString = "meow" or Err("property rollback failed")


assert:
    T := native_property_rollback_test{}
    set T.MyObject = tiny_native_class{X := 123}
    if:
        T.MyObject.X = 123 or Err("property test failed")
        set T.MyObject = tiny_native_class{X := 456}
        T.MyObject.X = 456 or Err("property change failed")
        false? # rollback

    T.MyObject.X = 123 or Err("property rollback failed")


TestClass1 := class {}
TestClass2 := class {}

assert:
    T := native_property_rollback_test{}
    set T.MyType = TestClass1
    if:
        TestUtils.AreClassesEqual[T.MyType, TestClass1] or Err("property test failed")
        set T.MyType = TestClass2
        TestUtils.AreClassesEqual[T.MyType, TestClass2] or Err("property change failed")
        false? # rollback

    TestUtils.AreClassesEqual[T.MyType, TestClass1] or Err("property rollback failed")
