# Ensure abstract class may not be instantiated
assert_semantic_error(3571):
    
    ClassA := class<abstract>:
        method():void=
        {
            a := ClassA{}
        }

# Ensure a non-abstract subclass of an abstact class may be instantiated
assert_valid:
    
    ClassA := class<abstract> {}

    ClassB := class(ClassA):
        method():void=
        {
            b := ClassB{}
        }

assert_semantic_error(3596):
    clazz1 := class<abstract>{Foo<abstract>():void}

assert_valid:
    clazz2 := class<abstract>{Foo():void}

assert_valid:
    clazz3 := class<abstract>{Foo():void}
    clazz4 := class<abstract>(clazz3){}

assert_semantic_error(3591):
    clazz5 := class<abstract>{Foo():void}
    clazz6 := class(clazz5){}

assert_semantic_error(3591):
    clazz7 := class{Foo():void}

assert_semantic_error(3591, 3591):
    clazz8 := class{Foo():void}
    clazz9 := class(clazz8){}

assert_semantic_error(3596):
    clazz10 := class<abstract>{Foo<abstract>():void = {}}

assert_semantic_error(3596):
    clazz11 := class<abstract>{Foo<abstract>:int}

assert_valid:
    interfase1 := interface{Foo():void}
    clazz12 := class<abstract>(interfase1){}

# --- Interfaces ---

# <abstract> is rejected on an interface type and on interface members; only a class may be abstract.
assert_semantic_error(3596):
    interfase2 := interface<abstract> {}

assert_semantic_error(3596):
    interfase3 := interface<abstract>{Method():int}

assert_semantic_error(3596):
    interfase4 := interface{Method<abstract>():int}

assert_semantic_error(3596):
    interfase5 := interface{Method<abstract>():int = 42}

assert_semantic_error(3596):
    interfase6 := interface{Value<abstract>:int}

# --- Structs ---

# <abstract> is rejected on a struct type and on struct members.
assert_semantic_error(3596):
    strukt1 := struct<abstract> {}

assert_semantic_error(3596):
    strukt2 := struct{Value<abstract>:int}

# An interface requirement may be left unimplemented through an abstract class and satisfied by an
# override in the first concrete subclass.
assert_valid:
    interfase7 := interface{Method():int}
    clazz13 := class<abstract>(interfase7){}
    clazz14 := class(clazz13):
        Method<override>():int = 42

