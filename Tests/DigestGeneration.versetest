# Basic digest generation tests.
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            Module<public> := module:
                Class<public> := class:
                    FieldA<public>():void = {}
                    FieldB():void = {}
                    FieldC<public>:int = 42

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            Class<public> := class:
                FieldA<public>():void = external {}

                FieldC<public>:int = external {}
}

# Test with multiple snippets.
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            Module<public> := module:
                Class<public> := class:
                    FieldA<public>():void = {}
                    FieldB():void = {}
                    FieldC<public>:int = 42

        snippet:
            Module2<public> := module:
                Class<public> := class:
                    FieldD<public>():void = {}
                    FieldE():void = {}
                    FieldF<public>:int = 42

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            (/A/Module:)Class<public> := class:
                FieldA<public>():void = external{}

                FieldC<public>:int = external{}

        # Module import path: /A/Module2
        Module2<public> := module:
            (/A/Module2:)Class<public> := class:
                FieldD<public>():void = external{}

                FieldF<public>:int = external{}
}

# Basic test of public/epic_internal digests.
assert_digest_generated
{
    vpackage(P0, /A, ?Scope := InternalUser):
        snippet:
            Module<public> := module:
                Class<public> := class:
                    FieldA<public>():void = {}
                    FieldB():void = {}
                    FieldC<epic_internal>():void = {}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            Class<public> := class:
                FieldA<public>():void = external{}

    expected_digest(Package := P0, ?Variant := PublicAndEpicInternal):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            Class<public> := class:
                FieldA<public>():void = external{}

                FieldC<epic_internal>():void = external{}
}

# TODO: A non-visible interface field should not generate an overridden field definition in the digest,
# but today, we make them show up anyway because the asset manifest today relies on this implementation detail for
# generating `scoped` definitions regardless that are preserved to the final asset digest.
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            Module<public> := module:
                Interface := interface:
                    FieldA<scoped{/A}>():void = {}

                Class<public> := class(Interface):
                    FieldA<override>():void = {}
                    FieldB<public>():void = {}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            Class<public> := class:
                FieldA<override>():void = external{}

                FieldB<public>():void = external{}
}

# Interfaces that have fields with default values should not have their IR-generated definitions show up in the digest.
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            Module<public> := module:
                Interface := interface:
                    FieldA<public>:int = 42
                    FieldB<public>():int = { 42 + 42 }

                Class<public> := class(Interface):
                    FieldA<override>:int = 84
                    FieldB<override>():int = 100

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            Class<public> := class:
                FieldA<override>:int = external{}

                FieldB<override>():int = external{}
}

# Check that the correct digest is generated appropriately for different accessibility contexts.
assert_digest_generated
{
    vpackage(P0, /A, ?Scope := InternalUser):
        snippet:
            Module<public> := module:
                Interface<epic_internal>(t:type) := interface:
                    Method():t

                SubInterface<epic_internal> := interface(Interface(float)) {}
                Class<epic_internal> := class(SubInterface):
                    Method<override>():float = { return 0.0 }

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:

    expected_digest(Package := P0, ?Variant := PublicAndEpicInternal):
        # Verse path: /A
        # Module import path: /A/Module
        Module<public> := module:
            Interface<epic_internal>(t:type) := interface:

                (/A/Module/Interface:)Module_Interface_Variance<private>():tuple(t) = external {}

            SubInterface<epic_internal> := interface(Interface(float)):

            Class<epic_internal> := class(SubInterface):
}

# Test that using an alias to act as the accessibility specifier works.
# assert_digest_generated
# {
#     vpackage(P0, /A, ?Scope := InternalUser):
#         snippet:
#             ModuleTest<public> := module:
#                 alias_scope<epic_internal> := epic_internal
#                 Interface<alias_scope>(t:type) := interface:
#                     Method():t

#                 SubInterface<alias_scope> := interface(Interface(float)) {}
#                 Class<alias_scope> := class(SubInterface):
#                     Method<override>():float = { return 0.0 }

#     expected_digest(Package := P0, ?Variant := PublicOnly):
#         # Module import path: /A/ModuleTest
#         ModuleTest<public> := module:

#     # TODO: In the future, we want `Interface`/`SubInterface`/`Class` to show `alias_scope` instead of `epic_internal`.
#     expected_digest(Package := P0, ?Variant := PublicAndEpicInternal):
#         # Module import path: /A/ModuleTest

#         ModuleTest<public> := module:

#             alias_scope<epic_internal> := epic_internal

#             Interface<epic_internal>(t:type) := interface:

#                 (/A/ModuleTest/Interface:)ModuleTest_Interface_Variance<private>:?type {_():tuple(t)} = external {}

#             SubInterface<epic_internal> := interface(Interface(float)):

#             Class<epic_internal> := class(SubInterface):
# }

# Test that using an alias with an access specifier that is also an alias works.
# assert_digest_generated
# {
#     vpackage(P0, /A, ?Scope := InternalUser):
#         snippet:
#             ModuleTest<public> := module:
#                 alias_scope<alias_scope> := epic_internal
#                 Interface<alias_scope>(t:type) := interface:
#                     Method():t

#                 SubInterface<alias_scope> := interface(Interface(float)) {}
#                 Class<alias_scope> := class(SubInterface):
#                     Method<override>():float = { return 0.0 }

#     expected_digest(Package := P0, ?Variant := PublicOnly):
#         # Module import path: /A/ModuleTest
#         ModuleTest<public> := module:

#     # TODO: In the future, we want `Interface`/`SubInterface`/`Class` to show `alias_scope` instead of `epic_internal`.
#     expected_digest(Package := P0, ?Variant := PublicAndEpicInternal):
#         # Module import path: /A/ModuleTest

#         ModuleTest<public> := module:

#             alias_scope<epic_internal> := epic_internal

#             Interface<epic_internal>(t:type) := interface:

#                 (/A/ModuleTest/Interface:)ModuleTest_Interface_Variance<private>:?type {_():tuple(t)} = external {}

#             SubInterface<epic_internal> := interface(Interface(float)):

#             Class<epic_internal> := class(SubInterface):
# }

# No variance requirement
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class{}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type) := class:
}

# Covariant requirement
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class:
                Data<private>:?t = false

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type) := class:
            (/A/class1:)class1_Variance<private>():tuple(t) = external{}
}

# Contravariant requirement
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class:
                Method<private>(:t):void = {}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type) := class:
            (/A/class1:)class1_Variance<private>(:t):tuple() = external{}
}

# Covariant and contravariant requirement
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class:
                Method<private>(X:t):t = X

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type) := class:
            (/A/class1:)class1_Variance<private>(:t):tuple(t) = external{}
}

# Multiple variance requirements
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type, u:type) := class:
                Method<private>(X:t):t = X
                Data<private>:?u = false

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type, u:type) := class:
            (/A/class1:)class1_Variance<private>(:t):tuple(t, u) = external{}
}

# Nested variance (only immediate parametric types should be used).
assert_digest_generated
{
    vpackage(P0, /A):
        snippet:
            class1<public>(t:type) := class:
                Data<private>:?t = false
            class2<public>(u:type) := class:
                Data1<private>:class1(u) = class1(u){}
                Data2<private>:class1(int) = class1(int){}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        class1<public>(t:type) := class:
            (/A/class1:)class1_Variance<private>():tuple(t) = external{}
        class2<public>(u:type) := class:
            (/A/class2:)class2_Variance<private>():tuple(u) = external{}
}

