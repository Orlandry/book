    set T.MyTuple = ('A', 'B', 'C')
    if:
        T.MyTuple = ('A', 'B', 'C') or Err("property test failed")
        set T.MyTuple = ('1', '2', '3')
        T.MyTuple = ('1', '2', '3') or Err("property change failed")
        false? # rollback

    T.MyTuple = ('A', 'B', 'C') or Err("property rollback failed")


