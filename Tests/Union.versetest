Equal(X:t, Y:comparable where t:subtype(comparable))<computes><decides>:t =
    X = Y

assert:
    logic{Equal[UF.N(1), UF.N(1)]} = true

assert:
    logic{Equal[UF.N(0), UF.N(1)]} = false

variant_types := union:
    String : string
    Int : int
    Logic : logic
    Other : void

VariantTypesAsString(VariantTypes : variant_types):string=
    case(VariantTypes):
        variant_types.String(String : string) => String
        variant_types.Int(Number : int) => DebugToString(Number)
        variant_types.Logic(Logic : logic) => if(Logic?){"true"}else{"false"}
        _=> "Nothing"

# Test for duplicate variants causing a compiler error
assert_semantic_error(3616):
    variant_types := union:
        String : string
        Int : int
        Logic : logic
        Other : void

    VariantTypesAsStringCompileError(VariantTypes : variant_types):string=
        case(VariantTypes):
            variant_types.String(String : string) => String
            variant_types.Int(Int : int) => "Number"
            variant_types.Int(Number : int) => "NUMBER"
            variant_types.Logic(Logic : logic) => if(Logic?){"true"}else{"false"}
            _=> "Nothing"
assert:
    VariantTypesAsString(variant_types.String("TripleT")) = "TripleT"
    VariantTypesAsString(variant_types.Logic(true)) = "true"
    VariantTypesAsString(variant_types.Int(67)) = "67"
    VariantTypesAsString(variant_types.Other()) = "Nothing"
    
