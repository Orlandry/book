    T := native_property_rollback_test{}
    set T.MyEnum = Numbers.One
    if:
        T.MyEnum = Numbers.One or Err("property test failed")
        set T.MyEnum = Numbers.Two
        T.MyEnum = Numbers.Two or Err("property change failed")
        false? # rollback

    T.MyEnum = Numbers.One or Err("property rollback failed")


assert:
    T := native_property_rollback_test{}
    set T.MyArray = array{1, 2, 3}
    if:
        T.MyArray = array{1, 2, 3} or Err("property test failed")
        set T.MyArray = array{4, 5, 6, 7}
        T.MyArray = array{4, 5, 6, 7} or Err("property change failed")
        false? # rollback

    T.MyArray = array{1, 2, 3} or Err("property rollback failed")


assert:
    T := native_property_rollback_test{}
    set T.MyMap = map{'a' => 1, 'b' => 2, 'c' => 3}
    if:
        T.MyMap = map{'a' => 1, 'b' => 2, 'c' => 3} or Err("property test failed")
        set T.MyMap = map{'d' => 4, 'e' => 5}
        T.MyMap = map{'d' => 4, 'e' => 5} or Err("property change failed")
        false? # rollback

    T.MyMap = map{'a' => 1, 'b' => 2, 'c' => 3} or Err("property rollback failed")


