            Class<public> := class:

        @available{MinUploadedAtFNVersion:=1338}
        # Module import path: /A/Module2
        Module2<public> := module:
            using {/A}
            Class2<public> := (/A:)Module.Class
}

assert_digest_generated
{
    vpackage(P0, /A, ?Scope := InternalUser):
        snippet:
            using { /Verse.org/Native }
            Module<public> := module:
                Class<public> := class{}

            using { /Verse.org/Native }
            Module2<public> := module:
                Class<public> := class{}

            using { /Verse.org/Native }
            @available{MinUploadedAtFNVersion:=1339}
            Module3<public> := module:
                using { /A/Module }
                using { /A/Module2 }
                Foo<public>(C1:(/A/Module:)Class, C2:(/A/Module2:)Class):void := {}

    expected_digest(Package := P0, ?Variant := PublicOnly):
        # Verse path: /A
        using {/Verse.org/Native}
        # Module import path: /A/Module
        Module<public> := module:
            (/A/Module:)Class<public> := class:

        # Module import path: /A/Module2
        Module2<public> := module:
            (/A/Module2:)Class<public> := class:

        @available{MinUploadedAtFNVersion:=1339}
        # Module import path: /A/Module3
        Module3<public> := module:
            using { /A/Module2 }
            using { /A/Module }
            Foo<public>(C1:(/A/Module:)Class, C2:(/A/Module2:)Class):void = external {}
}

