# Can't compare a variant that's in a union that contains non-comparable variant payloads
assert_semantic_error(3509):
    struct_ := struct{S : string}
    class_ := class{_Struct : struct_}
    union_ := union:
        S : string
        N : int
        F : float
        L : logic
        Stru : struct_
        C : class_
    # Array to map
    UArray_ : []union_ = array{union_.S("Fizz"), union_.N(6), union_.F(6.6), union_.L(true)}
    UMap : [union_]int = map{}

union_ := union:
    S : string
    N : int
    F : float
    L : logic

# You can compare and hash comparable/hashable 
assert:
    # Array to map
    UArray_ : []union_ = array{union_.S("Fizz"), union_.N(6), union_.F(6.6), union_.L(true)}
    var UMap : [union_]int = map{}
    var Index : int = 0

    for(U : UArray_):
        set UMap[U] = Index
        set Index += 1

    var NewUArray_ : []union_ = array{}
    for(U -> V : UMap):
        set NewUArray_ += array{U}

    for(U : NewUArray_):
        logic{UMap[U]} = true

# Specifiers
assert_valid:
    u<public> := union{N : int}

assert_valid:
    u := union<converges>{N : int}

assert_valid:
    u := union<computes>{N : int}

assert_semantic_error(3596):
    u := union<decides>{N : int}
    
assert_semantic_error(3604):
    u := union{N<public> : int}
    
assert_semantic_error(3604):
    u := union{N : int<decides>}

    U : u = u.N(6)
assert_semantic_error(3604):
    u := union{N<decides> : int}

    U : u = u.N(6)

# Reserved keywords
assert_semantic_error(3514):
    Self := union{N : int}
    
assert_semantic_error(3514):
    u := union{union : int}

}
